# 🛡️ HealthGuard AI - Backend Environment Configuration

# 🚀 Server Settings
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# 💾 Database & Security
# Prefer DATABASE_URL for managed Postgres providers like Aiven/Cloud SQL.
DATABASE_URL=postgres://user:password@host:5432/database?sslmode=require
DB_SSLMODE=require
# Use false for Aiven unless you provide the CA certificate to Node.
DB_SSL_REJECT_UNAUTHORIZED=false
DB_NAME=healthguard
DB_USER=healthguard_user
DB_PASSWORD=your_postgres_password_here
DB_HOST=localhost
DB_PORT=5432
JWT_SECRET=change_this_to_a_long_random_string_for_production

# 🧠 AI Engine Config
GROQ_API_KEY=your_groq_api_key_here

# 🌍 Environmental Context
WEATHER_API_KEY=your_openweather_api_key_here
