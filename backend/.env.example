# 🛡️ HealthGuard AI - Backend Environment Configuration

# 🚀 Server Settings
PORT=5000
NODE_ENV=development

# 🧠 AI Engine Config (Groq / Gemini)
# Obtain from: https://console.groq.com/ or https://aistudio.google.com/
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# 🌍 Environmental Context (OpenWeather)
# Obtain from: https://openweathermap.org/api
WEATHER_API_KEY=your_openweather_api_key_here

# 💾 Database & Security
# Local: mongodb://localhost:27017/healthguard
# Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/healthguard
MONGO_URI=mongodb://localhost:27017/healthguard
JWT_SECRET=change_this_to_a_long_random_string_for_production
